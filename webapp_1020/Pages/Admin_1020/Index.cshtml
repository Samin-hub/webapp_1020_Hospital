@page
@model webapp_1020.Pages.Admin_1020.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="card p-4 bg-white shadow-sm border-0 rounded-3 mb-4">
    <h2 class="text-primary fw-bold">👨‍⚕️ অ্যাডমিন কন্ট্রোল প্যানেল</h2>
    <p class="text-muted">স্বাগতম! এখান থেকে হসপিটালের সমস্ত অ্যাপয়েন্টমেন্ট এবং পেশেন্ট রেকর্ড নিয়ন্ত্রণ করা যাবে।</p>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card bg-primary text-white border-0 shadow-sm rounded-3 p-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase text-white-50">মোট ক্যাটাগরি</h6>
                    <h1 class="display-5 fw-bold mb-0">@Model.TotalCategories</h1>
                </div>
                <div class="fs-1">📂</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-success text-white border-0 shadow-sm rounded-3 p-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase text-white-50">মোট ডাক্তার</h6>
                    <h1 class="display-5 fw-bold mb-0">@Model.TotalDoctors</h1>
                </div>
                <div class="fs-1">👨‍⚕️</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-warning text-dark border-0 shadow-sm rounded-3 p-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase text-dark-50">মোট অ্যাপয়েন্টমেন্ট</h6>
                    <h1 class="display-5 fw-bold mb-0">@Model.TotalAppointments</h1>
                </div>
                <div class="fs-1">📅</div>
            </div>
        </div>
    </div>
</div>