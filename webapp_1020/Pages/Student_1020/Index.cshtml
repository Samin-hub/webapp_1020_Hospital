@page
@model webapp_1020.Pages.Student_1020.IndexModel
@{
    ViewData["Title"] = "পেশেন্ট ড্যাশবোর্ড";
}

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h2 class="text-info fw-bold">🩺 আমার মেডিকেল পোর্টাল (স্টুডেন্ট)</h2>
        <p class="text-muted">আপনার লগইন করা অ্যাকাউন্ট: <strong>@User.Identity?.Name</strong></p>
    </div>
    <div class="col-md-6 text-md-end">
        <a asp-page="Create" class="btn btn-info btn-lg text-white fw-bold shadow-sm">+ নতুন অ্যাপয়েন্টমেন্ট বুক করুন</a>
    </div>
</div>

<div class="card p-3 mb-4 shadow-sm border-0 bg-white">
    <form method="get" class="row g-3 align-items-center">
        <div class="col-sm-9">
            <input type="text" asp-for="SearchString" class="form-control" placeholder="🔍 ডাক্তারের নাম অথবা স্ট্যাটাস (যেমন: Pending, Approved) লিখে সার্চ করুন..." />
        </div>
        <div class="col-sm-3 d-grid">
            <button type="submit" class="btn btn-dark fw-bold">ফিল্টার করুন</button>
        </div>
    </form>
</div>

<div class="card student-card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-info text-dark">
                <tr>
                    <th class="ps-4">রোগীর নাম</th>
                    <th>ডাক্তার</th>
                    <th>তারিখ ও সময়</th>
                    <th>মোবাইল নম্বর</th>
                    <th class="text-center pe-4">স্ট্যাটাস</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Appointment.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">কোনো অ্যাপয়েন্টমেন্টের রেকর্ড পাওয়া যায়নি।</td>
                    </tr>
                }
                @foreach (var item in Model.Appointment)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-secondary">👤 @item.PatientName</td>
                        <td class="fw-bold text-dark">👨‍⚕️ @item.Doctor?.Name</td>
                        <td>@item.AppointmentDate.ToString("dd MMM yyyy - hh:mm tt")</td>
                        <td>@item.Phone</td>
                        <td class="text-center pe-4">
                            @if (item.Status == "Approved")
                            {
                                <span class="badge bg-success p-2">Approved</span>
                            }
                            else if (item.Status == "Cancelled")
                            {
                                <span class="badge bg-danger p-2">Cancelled</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark p-2">Pending</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>