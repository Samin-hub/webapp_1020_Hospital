@page
@model webapp_1020.Pages.Student_1020.CreateModel
@{
    ViewData["Title"] = "অ্যাপয়েন্টমেন্ট বুকিং";
}

<div class="container mt-4" style="max-width: 650px;">
    <div class="card student-card border-0 shadow-lg">
        <div class="card-header bg-info text-white p-3 text-center">
            <h4 class="mb-0">📅 নতুন ডাক্তার অ্যাপয়েন্টমেন্ট বুকিং ফরম</h4>
        </div>
        <div class="card-body p-4 bg-white">
            <form method="post">
                <!-- রানিং ইউজারের ইমেইল দেখানোর জন্য -->
                <div class="form-group mb-3">
                    <label class="control-label fw-bold mb-1">আপনার রেজিস্টার্ড ইমেইল:</label>
                    <input type="text" class="form-control bg-light text-muted" value="@User.Identity?.Name" readonly />
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold mb-1">রোগীর সম্পূর্ণ নাম:</label>
                    <input asp-for="PatientName" class="form-control" placeholder="রোগীর নাম লিখুন" required />
                    <span asp-validation-for="PatientName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold mb-1">যোগাযোগের মোবাইল নম্বর:</label>
                    <input asp-for="Phone" class="form-control" placeholder="যেমন: 017XXXXXXXX" required />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold mb-1">কাঙ্ক্ষিত ডাক্তার সিলেক্ট করুন:</label>
                    <select asp-for="DoctorId" class="form-select" asp-items="ViewBag.DoctorId" required>
                        <option value="">-- ডাক্তার বেছে নিন --</option>
                    </select>
                    <span asp-validation-for="DoctorId" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label class="control-label fw-bold mb-1">তারিখ ও সময়:</label>
                    <input asp-for="AppointmentDate" class="form-control" type="datetime-local" required />
                    <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-page="Index" class="btn btn-outline-secondary px-4">🔙 আমার বুকিং তালিকা</a>
                    <button type="submit" class="btn-success-custom px-4 py-2">কনফার্ম বুকিং 🚀</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
        TempData["SuccessMessage"] = "আপনার অ্যাপয়েন্টমেন্টটি সফলভাবে বুক করা হয়েছে!";
    }
}