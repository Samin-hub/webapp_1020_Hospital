@page
@model webapp_1020.Pages.Admin_1020.Categories.IndexModel
@{
    ViewData["Title"] = "ক্যাটাগরি তালিকা";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold">📋 ডাক্তারের ক্যাটাগরি বা ডিপার্টমেন্ট সমূহ</h2>
    <a asp-page="Create" class="btn-success-custom">+ নতুন ক্যাটাগরি যোগ করুন</a>
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">আইডি</th>
                    <th>ক্যাটাগরির নাম</th>
                    <th>বিবরণ</th>
                    <th class="text-end pe-4">অ্যাকশন</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Category.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">কোনো ক্যাটাগরি পাওয়া যায়নি। নতুন যোগ করুন!</td>
                    </tr>
                }
                @foreach (var item in Model.Category)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-secondary">@item.Id</td>
                        <td class="fw-bold">@item.Name</td>
                        <td class="text-muted">@item.Description</td>
                        <td class="text-end pe-4">
                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-2">সম্পাদনা</a>
                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">মুছে ফেলুন</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>