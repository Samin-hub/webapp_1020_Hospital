@page
@model webapp_1020.Pages.Admin_1020.Categories.CreateModel
@{
    ViewData["Title"] = "নতুন ক্যাটাগরি";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow border-0 rounded-3">
        <div class="card-header bg-primary text-white p-3">
            <h4 class="mb-0">➕ নতুন ডিপার্টমেন্ট/ক্যাটাগরি যোগ করুন</h4>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="Category.Name" class="control-label fw-bold mb-1">ক্যাটাগরির নাম:</label>
                    <input asp-for="Category.Name" class="form-control" placeholder="যেমন: Cardiology, Neurologist" />
                    <span asp-validation-for="Category.Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Category.Description" class="control-label fw-bold mb-1">বিবরণ:</label>
                    <textarea asp-for="Category.Description" class="form-control" rows="3" placeholder="বিভাগীয় সংক্ষিপ্ত বিবরণ লিখুন..."></textarea>
                    <span asp-validation-for="Category.Description" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-page="Index" class="btn btn-outline-secondary px-4">🔙 তালিকায় ফিরে যান</a>
                    <button type="submit" class="btn-primary-custom">সংরক্ষণ করুন</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}